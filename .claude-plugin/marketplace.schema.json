{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/claude-marketplace.schema.json",
  "title": "Claude Code Marketplace",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "owner", "plugins"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Marketplace identifier (kebab-case recommended)",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "owner": {
      "$ref": "#/$defs/person"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "version": { "type": "string" },
        "pluginRoot": { "type": "string" }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/plugin"
      }
    }
  },
  "$defs": {
    "person": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      }
    },

    "pluginSource": {
      "oneOf": [
        {
          "type": "string",
          "description": "Relative path to plugin in same repo, e.g. ./plugins/foo"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["source"],
          "properties": {
            "source": {
              "type": "string",
              "enum": ["github", "url"]
            },
            "repo": {
              "type": "string",
              "description": "GitHub repo in owner/name form"
            },
            "url": {
              "type": "string",
              "format": "uri"
            }
          },
          "allOf": [
            {
              "if": {
                "properties": { "source": { "const": "github" } }
              },
              "then": {
                "required": ["repo"]
              }
            },
            {
              "if": {
                "properties": { "source": { "const": "url" } }
              },
              "then": {
                "required": ["url"]
              }
            }
          ]
        }
      ]
    },

    "hookCommand": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "command"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["command"]
        },
        "command": {
          "type": "string"
        }
      }
    },

    "hookMatcher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["matcher", "hooks"],
      "properties": {
        "matcher": {
          "type": "string"
        },
        "hooks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hookCommand"
          }
        }
      }
    },

    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "source": {
          "$ref": "#/$defs/pluginSource"
        },

        "description": { "type": "string" },
        "version": { "type": "string" },
        "homepage": { "type": "string", "format": "uri" },
        "repository": { "type": "string", "format": "uri" },
        "license": { "type": "string" },
        "keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "category": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },

        "author": {
          "$ref": "#/$defs/person"
        },

        "strict": {
          "type": "boolean",
          "default": true,
          "description": "If true, plugin.json must exist in plugin source"
        },

        "commands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "agents": {
          "type": "array",
          "items": { "type": "string" }
        },

        "hooks": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/hookMatcher"
            }
          }
        },

        "mcpServers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true,
            "required": ["command"],
            "properties": {
              "command": { "type": "string" },
              "args": {
                "type": "array",
                "items": { "type": "string" }
              },
              "env": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
